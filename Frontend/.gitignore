# Frontend-specific ignores (root .gitignore also applies)

# Dependencies
node_modules/

# Build output
dist/
dist-ssr/
build/

# Vite
.vite/
*.local

# Secrets
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Test / coverage
coverage/

# TypeScript
*.tsbuildinfo

# Editor
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
