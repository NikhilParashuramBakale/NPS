APP_ENV=prod
DATABASE_URL=postgresql+psycopg://user:password@host:5432/nps
JWT_SECRET=change-this-before-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120
CORS_ORIGINS=https://your-frontend-domain.example
PAKE_SERVER_ID=securecam-backend
PAKE_KDF_AAD=securecam-v1
PAKE_SCRYPT_N=16384
PAKE_SCRYPT_R=8
PAKE_SCRYPT_P=1
PAKE_SESSION_TTL_SECONDS=300
