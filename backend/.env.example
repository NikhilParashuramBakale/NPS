APP_ENV=dev
DATABASE_URL=sqlite:///./nps.db
JWT_SECRET=change-this-before-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120
CORS_ORIGINS=http://localhost:5173
PAKE_SERVER_ID=securecam-backend
PAKE_KDF_AAD=securecam-v1
PAKE_SCRYPT_N=16384
PAKE_SCRYPT_R=8
PAKE_SCRYPT_P=1
PAKE_SESSION_TTL_SECONDS=300
