# Backend-specific ignores (root .gitignore also applies)

# Secrets — never commit real env files
.env
.env.local
.env.*.local
.env.dev
.env.prod
.env.test
!.env.example

# Python bytecode & caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
pytest-cache-files-*/

# Virtual environments
venv/
.venv/
env/

# Local SQLite database
*.db
*.sqlite
*.sqlite3

# Node deps for pake_cli.cjs / spake2
node_modules/

# Test / coverage output
.coverage
htmlcov/
.tox/

# Build artifacts
build/
dist/
*.egg-info/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db
